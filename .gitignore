# RSR-compliant .gitignore

# OS & Editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Build (unanchored to match nested monorepo paths)
target/
_build/
/build/
/dist/
/out/

# Dependencies (unanchored to match nested monorepo paths)
node_modules/
/vendor/
deps/
.elixir_ls/

# BEAM compiled files
*.beam

# Rust
# Cargo.lock  # Keep for binaries

# Elixir
/cover/
/doc/
*.ez
erl_crash.dump

# Julia
*.jl.cov
*.jl.mem
/Manifest.toml

# ReScript
/lib/bs/
/.bsb.lock

# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/

# Ada/SPARK
*.ali
/obj/
/bin/

# Haskell
/.stack-work/
/dist-newstyle/

# Chapel
*.chpl.tmp.*

# Secrets
.env
.env.*
*.pem
*.key
secrets/

# Test/Coverage
/coverage/
htmlcov/

# Logs
*.log
/logs/

# Temp
/tmp/
*.tmp
*.bak

# Crash recovery artifacts
ai-cli-crash-capture/
